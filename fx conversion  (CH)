-- fx_current_conversion_rate (ClickHouse) - Memory Optimized
-- Column sources unchanged from original query

WITH

a_conversion AS (
    SELECT `from`, max(created_at) AS last_time
    FROM datalake.clean_fx_log
    WHERE `to` = 'USD'
    GROUP BY `from`
),

conversion_data AS (
    SELECT DISTINCT
        a.`from`                             AS from_currency,
        CAST(b.base_rate AS Decimal(12, 10)) AS rate_in_usd
    FROM a_conversion a
    JOIN datalake.clean_fx_log b
        ON a.last_time = b.created_at AND a.`from` = b.`from`
),

payment_method_categories AS (
    SELECT
        payment_attempt_id,
        CASE
            WHEN lower(payment_method_type) LIKE '%card%'       THEN 'card'
            WHEN lower(payment_method_type) LIKE '%local%'      THEN 'local_transfer'
            WHEN lower(payment_method_type) LIKE '%wire%'       THEN 'wire_transfer'
            WHEN lower(payment_method_type) LIKE '%stablecoin%' THEN 'stablecoin'
            ELSE 'apm'
        END AS payment_method,
        payment_method_type
    FROM datalake.clean_payment_attempt
    WHERE status = 'succeeded'
      AND toDate(created_at) >= toDate('2026-03-05')   -- scope to date range
),

