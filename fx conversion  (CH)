-- payout
payout_calc AS (
    SELECT
        toDate(a.created_at)               AS created_at,
        'payout'                            AS object_type,
        transfer_type                       AS payment_method,
        a.currency                          AS payout_currency,
        a.holding_currency,
        c.`to`                              AS destination_currency,
        a.amount / 100.0                    AS payout_amount,
        abs(b.amount) / 100.0              AS holding_amount,
        (a.amount / 100.0) * c.final_rate   AS destination_amount
    FROM datalake.clean_payout a
    LEFT JOIN datalake.clean_balance_transaction b
        ON a.payout_id = b.reference_id
        -- AND b.transaction_type = 'payout'              -- narrow right-side scan
    LEFT JOIN datalake.clean_fx_quote c
        ON a.destination_fx_quote_id = c.quote_id
    WHERE a.status = 'succeeded'
      AND toDate(a.created_at) >= toDate('2026-03-08') -- direct WHERE
),

